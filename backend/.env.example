# Copy this file to .env and fill in your own local values.
# .env is not committed to Git - each developer creates their own.

# Format: postgresql://<username>:<password>@<host>:<port>/<database_name>
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/dms_db

# Used to sign login (JWT) tokens - use a long random string, especially in production
SECRET_KEY=change-this-to-a-random-secret

# How long a login token stays valid, in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60
